# Copy this file to config.env and fill in your values.
# config.env is NOT committed to git (contains secrets).

# ── LTE Modem (Quectel EC25/EG-25) ──────────────────────────────────────────
APN=gprs.swisscom.ch
MODEM_USER=gprs
MODEM_PASS=gprs

# ── AutoSSH Reverse Tunnel ───────────────────────────────────────────────────
# Each device gets its own port on the jump host.
# Ikarus-1 = 2010, Ikarus-2 = 2011, etc.
TUNNEL_HOST=192.33.89.14
TUNNEL_USER=pi
TUNNEL_PORT=2010
SSH_KEY=/home/pi/.ssh/luckyluke

# ── Station ───────────────────────────────────────────────────────────────────
# Unique per device. T001–T999 = testing/commissioning, A001–A999 = production.
STATION_ID=T010

# ── GNSS (u-blox) ────────────────────────────────────────────────────────────
# u-blox USB CDC = /dev/ttyACM0  |  GPIO UART = /dev/serial0
# (Quectel modem occupies ttyUSB0–ttyUSB3, do not use those)
GNSS_DEVICE=/dev/ttyACM0
# Operating baud rate (after config_ublox.py has run)
GNSS_BAUD=38400
# Factory-default baud for fresh/unconfigured chips
GNSS_INIT_BAUD=9600

# ── Data directories ─────────────────────────────────────────────────────────
RAWX_DIR=/home/pi/aware-pi-logger/data/rawx
UPLOAD_DIR=/home/pi/aware-pi-logger/data/upload_ready
ARCHIVE_DIR=/home/pi/aware-pi-logger/data/archive
ERROR_DIR=/home/pi/aware-pi-logger/data/upload_error

# ── AWARE server ─────────────────────────────────────────────────────────────
AWARE_API_URL=https://aware-ethz.ch/upload
AWARE_API_KEY=your_api_key_here
